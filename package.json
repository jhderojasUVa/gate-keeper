{
    "name": "@jhderojasUVa/gate-keeper",
    "version": "1.2.0",
    "description": "First line of defense of your trunk development",
    "main": "./dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsgo --build",
        "dev": "tsgo --build --watch",
        "typecheck": "npm run typecheck:src && npm run typecheck:test",
        "typecheck:src": "tsgo --noEmit",
        "typecheck:test": "tsgo --project tsconfig.test.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "npm run test:unit",
        "test:unit": "vitest run --coverage",
        "prepare": "husky install",
        "cz": "cz",
        "release": "standard-version",
        "release:minor": "standard-version --release-as minor",
        "release:patch": "standard-version --release-as patch",
        "release:major": "standard-version --release-as major"
    },
    "bin": {
        "gate-keeper": "./bin/gate-keeper.js",
        "gate-keeper-init": "./bin/gate-keeper-init.js"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jhderojasUVa/gate-keeper.git"
    },
    "keywords": [
        "trunk",
        "gate",
        "keeper",
        "code",
        "git"
    ],
    "author": "Jesus Angel Hernandez de Rojas <jhderojas@gmail.com>",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/jhderojasUVa/gate-keeper/issues"
    },
    "homepage": "https://github.com/jhderojasUVa/gate-keeper#readme",
    "devDependencies": {
        "@commitlint/cli": "19.3.0",
        "@commitlint/config-conventional": "19.2.2",
        "@eslint/js": "^9.5.0",
        "@stylistic/eslint-plugin-js": "^2.3.0",
        "@types/blessed": "^0.1.25",
        "@types/express": "^4.17.21",
        "@types/node": "^24.0.0",
        "@types/supertest": "^7.2.0",
        "@types/ws": "^8.5.10",
        "@typescript/native-preview": "beta",
        "@vitest/coverage-v8": "^1.6.0",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.5.0",
        "eslint-plugin-jsdoc": "^48.2.1",
        "globals": "^15.6.0",
        "husky": "^8.0.0",
        "standard-version": "^9.5.0",
        "supertest": "^7.2.2",
        "typescript": "npm:@typescript/typescript6@latest",
        "vitest": "^1.6.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "blessed": "^0.1.81",
        "express": "^4.19.2",
        "node-fetch": "^3.3.2",
        "selfsigned": "^2.4.1",
        "ws": "^8.17.1",
        "zod": "^4.3.6"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    }
}
